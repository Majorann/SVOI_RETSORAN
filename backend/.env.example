FLASK_SECRET_KEY=

# Public deployment URL. For Hugging Face Spaces use:
# PUBLIC_BASE_URL=https://mayaran-mdk2.hf.space
PUBLIC_BASE_URL=

# Optional storage backends.
APP_DATA_DIR=
DATABASE_URL=
REDIS_URL=

# Cookie/session settings.
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_PARTITIONED=0
TRUST_PROXY_HEADERS=0
AUTH_SESSION_COOKIE_NAME=auth_session
AUTH_SESSION_COOKIE_MAX_AGE_SECONDS=2592000

# Password hashing.
PASSWORD_HASH_METHOD=pbkdf2:sha256:600000

# Debug/diagnostics.
DEBUG_STORAGE_ENABLED=0
LOGIN_DEBUG_ENABLED=0
LOGIN_DEBUG_LOG_PATH=
SESSION_DEBUG_ENABLED=0
SESSION_DEBUG_LOG_PATH=

# Runtime tuning.
DB_KEEPALIVE_ENABLED=1
DB_KEEPALIVE_INTERVAL_SECONDS=600
MENU_CACHE_ENABLED=1
MENU_CACHE_TTL_SECONDS=600
MENU_CACHE_KEY=menu:items:v1
CHECKOUT_PREVIEW_MAX_AGE_SECONDS=1800
POSTGRES_STARTUP_RETRIES=4
POSTGRES_STARTUP_RETRY_DELAY_SECONDS=3
